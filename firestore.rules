rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isRequiredString(value) {
      return value is string && value.size() > 0;
    }

    // Claves de primer nivel permitidas en el documento de usuario.
    // Esto es la frontera de seguridad real: impide que se escriban
    // campos arbitrarios. La validacion de TIPOS por campo se hace en
    // la app (no en reglas) porque hacerla exhaustiva aqui supera el
    // presupuesto de evaluacion de Firestore Rules con payloads grandes.
    function allowedTopLevelKeys() {
      return [
        'uid',
        'empresa',
        'email',
        'displayName',
        'photoUrl',
        'profilePhotoUrl',
        'createdAt',
        'lastLoginAt',
        'onboardingCompleted',
        'profileCompleted',
        'authProvider',
        'onboardingCompletedAt',
        'updatedAt',
        'profile',
        'appearance',
        'lifestyle',
        'style',
        'preferences',
        'origin',
        'profileVisibility',
        'settings',
        'location',
        'travel',
        'photos',
        'profileCompletionPercent',
        'profileCompletionChecklist',
        'pendingProfileTasks',
        'profileCompletionRewardsClaimed',
        'availableProfileRewards',
        'isBot',
        'botProfileVersion',
        'botScenario',
        'seedQualityScore',
        'verification',
        'aiData',
        'aiVisualConsent',
        'aiVisualConsentVersion',
        'aiVisualEnabled',
        'onboardingDraft',
        'onboardingDraftUpdatedAt',
        'profilePrompts'
      ];
    }

    function hasOnlyAllowedTopLevelKeys(data) {
      return data.keys().hasOnly(allowedTopLevelKeys());
    }

    function touchesOnlyAllowedTopLevelKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedTopLevelKeys());
    }

    function changed(key) {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([key]);
    }

    // uid, createdAt y authProvider no pueden modificarse una vez fijados.
    function immutableFieldsUntouchedOrInitialized(uid) {
      return (
        !changed('uid')
        || request.resource.data.get('uid', null) == uid
      )
      && (
        !changed('createdAt')
        || resource.data.get('createdAt', null) == null
        || request.resource.data.get('createdAt', null) == resource.data.get('createdAt', null)
      )
      && (
        !changed('authProvider')
        || resource.data.get('authProvider', null) == null
        || request.resource.data.get('authProvider', null) == resource.data.get('authProvider', null)
      );
    }

    // Una vez completado el onboarding/perfil, no puede volver a false.
    function completionFlagsDoNotRegress() {
      return !(
        resource.data.get('onboardingCompleted', false) == true
        && request.resource.data.get('onboardingCompleted', false) == false
      ) && !(
        resource.data.get('profileCompleted', false) == true
        && request.resource.data.get('profileCompleted', false) == false
      );
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && hasOnlyAllowedTopLevelKeys(request.resource.data)
        && request.resource.data.keys().hasAll(['empresa'])
        && request.resource.data.get('uid', null) == uid
        && isRequiredString(request.resource.data.get('empresa', null));
      allow update: if isOwner(uid)
        && touchesOnlyAllowedTopLevelKeys()
        && request.resource.data.keys().hasAll(['empresa'])
        && isRequiredString(request.resource.data.get('empresa', null))
        && immutableFieldsUntouchedOrInitialized(uid)
        && completionFlagsDoNotRegress();
      allow delete: if isOwner(uid);

      // Consent ledger: append-only e inmutable (para poder probar
      // cumplimiento RGPD). El dueno crea y lee; nadie edita/borra.
      match /consentRecords/{recordId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      // Solicitudes de privacidad (export/erasure/disable). El cliente las crea
      // como 'pending'; el procesado lo hace el backend con privilegios.
      match /privacyRequests/{requestId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      // Auditoria ligera lado cliente del historial de cambios del usuario.
      match /auditEvents/{eventId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }
    }

    match /seed_profiles/{seedId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Perfiles publicos para el feed de descubrimiento. Cualquier sesion lee;
    // cada usuario solo escribe el SUYO (espejo de campos publicos), marcando
    // isBot=false. Datos privados (email, ajustes) siguen solo en users/{uid}.
    // El dueno publica su propio espejo publico (uid + isBot=false). El backend
    // (trigger onUserWrittenSyncDiscovery) tambien lo mantiene via Admin SDK,
    // pero permitir la escritura del dueno hace que el feed funcione SIN
    // desplegar Cloud Functions. Datos privados (email, ajustes) NO van aqui.
    match /discovery/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid)
        && request.resource.data.get('uid', null) == uid
        && request.resource.data.get('isBot', true) == false;
      allow delete: if isOwner(uid);
    }

    // --- Monetizacion: el cliente SOLO lee. Tier, saldo y ledger son
    // autoritativos en backend (Admin SDK bypassa reglas). El cliente nunca
    // concede entitlements ni modifica saldo. ---

    // Feature flags / kill switch. Lectura para cualquier sesion.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Telemetría de Attra Spark: append-only. Cualquier sesion crea eventos con
    // su propio uid; nadie lee/edita/borra desde el cliente (analítica backend).
    match /sparkAnalytics/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.get('uid', '') == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Telemetría del feed/embudo (impresiones, likes, matches, conversaciones).
    // Append-only: cada quien crea sus eventos con su uid; lectura/analítica en
    // backend. No se edita ni borra desde el cliente.
    match /feedEvents/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.get('uid', '') == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Perfiles ya mostrados al usuario (frecuencia de aparición / no repetir).
    // PRIVADO del dueño: solo él lee y escribe sus impresiones.
    match /seenProfiles/{uid}/seen/{otherUid} {
      allow read, write: if isOwner(uid);
    }

    // Bandeja de notificaciones in-app. PRIVADA del dueño: solo él lee y
    // gestiona las suyas (marcar leído/borrar). El backend (Admin SDK) también
    // escribe aquí cuando llega un like/match/mensaje.
    match /notifications/{uid}/items/{itemId} {
      allow read, write: if isOwner(uid);
    }

    // Entitlements autoritativos por usuario.
    match /userEntitlements/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Monedero de Attras (saldo). Solo lectura del dueno.
    match /attraWallets/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Boosts consumibles. `users/{uid}.wallet.boosts`, `boostSessions` y
    // `activeBoosts` son autoritativos del backend. El cliente puede leer los
    // boosts activos mínimos para ordenar el feed, pero nunca escribir saldo ni
    // contadores.
    match /boostSessions/{boostId} {
      allow read: if isSignedIn()
        && resource.data.get('userId', null) == request.auth.uid;
      allow write: if false;
    }

    match /activeBoosts/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /boostImpressions/{impressionId} {
      allow read, write: if false;
    }

    // Ledger de Attras: inmutable y solo backend. El dueno lee sus entradas.
    match /attraLedger/{ledgerId} {
      allow read: if isSignedIn()
        && resource.data.get('uid', null) == request.auth.uid;
      allow write: if false;
    }

    // Envios de Attras. Visibles para emisor y receptor; escritura backend.
    match /attraSends/{sendId} {
      allow read: if isSignedIn() && (
        resource.data.get('fromUid', null) == request.auth.uid
        || resource.data.get('toUid', null) == request.auth.uid
      );
      allow write: if false;
    }

    // --- Match y chat: el cliente SOLO lee lo suyo. Todas las escrituras
    // (likes, matches, chats, mensajes, bloqueos, reportes) pasan por Cloud
    // Functions con Admin SDK. El cliente nunca crea un match ni modifica
    // unreadCount ni envia mensajes directamente. ---

    function isParticipant(usersList) {
      return isSignedIn() && request.auth.uid in usersList;
    }

    // Likes: visibles para emisor y receptor (bandeja "te han dado like").
    match /likes/{likeId} {
      allow read: if isSignedIn() && (
        resource.data.get('fromUid', null) == request.auth.uid
        || resource.data.get('toUid', null) == request.auth.uid
      );
      allow write: if false;
    }

    // Dislikes: solo el emisor.
    match /dislikes/{dislikeId} {
      allow read: if isSignedIn()
        && resource.data.get('fromUid', null) == request.auth.uid;
      allow write: if false;
    }

    // Matches: solo los participantes.
    match /matches/{matchId} {
      allow read: if isParticipant(resource.data.get('users', []));
      allow write: if false;

      // Attra Spark: sesiones de juego del match. Cliente lee/escribe SOLO si es
      // participante del match padre (lo valida contra matches/{matchId}.users).
      // El doc es la sala en vivo (presencia/rondas/respuestas/reacciones). El
      // mensaje de sistema final en el chat lo inserta el backend (Cloud Func).
      match /sparkSessions/{sessionId} {
        function matchUsers() {
          return get(/databases/$(database)/documents/matches/$(matchId))
              .data.get('users', []);
        }
        allow read: if isParticipant(matchUsers());
        // Crear: solo un participante, declarándose como userA (anfitrión) y con
        // el otro participante como userB.
        allow create: if isParticipant(matchUsers())
          && sessionId == 'icebreaker_v1'
          && request.resource.data.get('userAId', '') == request.auth.uid
          && matchUsers().hasAll([
               request.resource.data.get('userAId', ''),
               request.resource.data.get('userBId', '')
             ]);
        // Actualizar: cualquier participante del match (responder/reaccionar/
        // presencia/avanzar). No se permite borrar.
        allow update: if isParticipant(matchUsers());
        allow delete: if false;
      }
    }

    // Chats: solo los participantes. Los mensajes heredan: se valida contra el
    // documento de chat padre.
    match /chats/{chatId} {
      allow read: if isParticipant(resource.data.get('users', []));
      allow write: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data.get('users', [])
        );
        allow write: if false;
      }

      // Respuestas privadas de minijuegos (Doble Respuesta / Dos Verdades).
      // Solo Cloud Functions con Admin SDK puede leer/escribir aqui. El cliente
      // recibe el resultado publico cuando ambos han respondido o se revela.
      match /privateAnswers/{answerId} {
        allow read, write: if false;
      }
    }

    // Bloqueos: solo quien bloquea ve su registro.
    match /blocks/{blockId} {
      allow read: if isSignedIn()
        && resource.data.get('blockerUid', null) == request.auth.uid;
      allow write: if false;
    }

    // Reportes: solo quien reporta; escritura y moderacion en backend.
    match /reports/{reportId} {
      allow read: if isSignedIn()
        && resource.data.get('reporterUid', null) == request.auth.uid;
      allow write: if false;
    }

    // Stories de video 24h. Lectura para cualquier sesion (el cliente oculta las
    // caducadas/expiradas y filtra bloqueados). Escritura SOLO backend
    // (createStory/viewStory/replyToStory/deleteStory + cleanup con Admin SDK).
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /views/{viewerUid} {
        allow read: if isSignedIn();
        allow write: if false;
      }
      match /replies/{replyId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }
  }
}
