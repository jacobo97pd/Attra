rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 8 * 1024 * 1024;
    }

    match /users/{uid}/private/live_selfie/{fileName} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && isImageUpload();
    }

    match /users/{uid}/public/profile/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) && isImageUpload();
    }

    match /users/{uid}/public/additional/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) && isImageUpload();
    }

    // Media de presentación del perfil (audio "voice prompt" + vídeo corto).
    // PÚBLICA: cualquier sesión la reproduce (las URLs llevan token). Solo el
    // dueño sube. Audio <=10MB, vídeo <=32MB (ya viene comprimido del cliente).
    match /users/{uid}/public/intro/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid)
        && (request.resource.contentType.matches('audio/.*')
            || request.resource.contentType.matches('video/.*'))
        && request.resource.size < 32 * 1024 * 1024;
    }

    match /seed_profiles/public/{fileName} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Media de chat. El usuario solo sube BAJO SU PROPIO uid (request.auth.uid).
    // La pertenencia al chat / chat activo / no-bloqueo se valida en la Cloud
    // Function sendMediaMessage (Storage Rules NO pueden leer la base nombrada
    // attra-database, por eso el backend es la autoridad). Lectura: cualquier
    // sesion (las URLs llevan token); el mensaje solo existe si el backend lo creo.
    match /chats/{chatId}/images/{uid}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid)
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Fotos bomba: el cliente solo sube. Nadie lee directamente desde reglas;
    // la Cloud Function openBombImage devuelve una URL temporal una sola vez.
    match /chats/{chatId}/bombs/{uid}/{fileName} {
      allow read: if false;
      allow write: if isOwner(uid)
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    match /chats/{chatId}/voice/{uid}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid)
        && request.resource.contentType.matches('audio/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Foto de referencia de la IA visual (Pro). PRIVADA: solo el dueño la sube
    // y la lee; el embedding lo calcula y guarda el backend (nunca el cliente).
    match /ai/{uid}/reference/{fileName} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && isImageUpload();
    }

    // Stories: el usuario sube SU video/thumb bajo su uid. La validacion de
    // limites/duracion/visibilidad la hace la Cloud Function createStory.
    match /stories/{uid}/{storyId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid)
        && (request.resource.contentType.matches('video/.*')
            || request.resource.contentType.matches('image/.*'))
        && request.resource.size < 16 * 1024 * 1024;
    }

    match /users/{uid}/{allPaths=**} {
      allow read, write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
